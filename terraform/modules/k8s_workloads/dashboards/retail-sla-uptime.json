      "id": 2,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "avg by (namespace, job) (avg_over_time(up{namespace=~\"ui|catalog|carts|checkout|orders\"}[5m])) * 100",
          "legendFormat": "{{namespace}}/{{job}}",
          "refId": "A"
        }
      ],
      "title": "Availability by Service",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
