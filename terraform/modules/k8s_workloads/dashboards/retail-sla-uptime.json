      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (namespace, job, le) (rate(http_server_requests_seconds_bucket{namespace=~\"ui|catalog|carts|checkout|orders\"}[5m])))",
          "legendFormat": "{{namespace}}/{{job}}",
          "refId": "A"
        }
      ],
      "title": "P95 Latency",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 7
      },
      "id": 5,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "100 * ((sum by (namespace, job) (rate(http_server_requests_seconds_count{namespace=~\"ui|catalog|carts|checkout|orders\",status=~\"5..\"}[5m]))) or on (namespace, job) (0 * sum by (namespace, job) (rate(http_server_requests_seconds_count{namespace=~\"ui|catalog|carts|checkout|orders\"}[5m])))) / clamp_min(sum by (namespace, job) (rate(http_server_requests_seconds_count{namespace=~\"ui|catalog|carts|checkout|orders\"}[5m])), 0.001)",
          "legendFormat": "{{namespace}}/{{job}}",
          "refId": "A"
        }
      ],
      "title": "5xx Error Rate",
      "type": "timeseries"
    }
