        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "avg(avg_over_time(up{namespace=~\"ui|catalog|carts|checkout|orders\"}[5m])) * 100",
