      "targets": [
        {
          "expr": "100 * sum by (namespace, pod) (rate(container_cpu_usage_seconds_total{namespace=~\"ui|catalog|carts|checkout|orders\",container!=\"\",container!=\"POD\"}[5m])) / clamp_min(sum by (namespace, pod) (kube_pod_container_resource_limits{namespace=~\"ui|catalog|carts|checkout|orders\",resource=\"cpu\",unit=\"core\"}), 0.001)",
          "legendFormat": "{{namespace}}/{{pod}}",
          "refId": "A"
        }
      ],
